{
  "name": "@trelyan/verify-pqc",
  "version": "0.2.0",
  "description": "Dependency-free toolkit to inspect Falcon-1024 signatures and verify post-quantum inscriptions on Algorand (AVM falcon_verify). Optional ML-DSA-87 STH verification. Node + browser.",
  "license": "MIT",
  "main": "index.js",
  "browser": "index.js",
  "type": "commonjs",
  "files": ["index.js", "mldsa.mjs", "slhdsa.mjs", "throndar-sth-key.mjs", "throndar-slh-key.mjs", "README.md"],
  "exports": {
    ".": "./index.js",
    "./mldsa": "./mldsa.mjs",
    "./slhdsa": "./slhdsa.mjs"
  },
  "keywords": ["post-quantum", "pqc", "falcon", "falcon-1024", "fn-dsa", "ml-dsa", "ml-dsa-87", "dilithium", "algorand", "falcon_verify", "signature", "verification", "trelyan"],
  "scripts": {
    "test": "node test.js"
  },
  "optionalDependencies": {
    "@noble/post-quantum": "^0.6.1",
    "@noble/hashes": "^1.8.0"
  },
  "engines": { "node": ">=18" }
}
